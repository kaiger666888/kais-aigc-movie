# Pixabay API Key (images/videos only, music requires browser download)
PIXABAY_API_KEY=55345251-e8bb128226740a411a1fc3083

# How to download music from Pixabay:
# 1. Open https://pixabay.com/music/search/<keyword>/
# 2. Click "Free Download" on desired tracks
# 3. Save MP3 files to appropriate category folder
# 
# Recommended search terms for this project:
# - "emotional piano" (温暖治愈)
# - "warm piano" (温暖钢琴)  
# - "sad piano" (忧伤钢琴)
# - "cinematic piano" (电影感钢琴)
# - "ambient piano" (氛围钢琴)
#
# Category folders:
# emotional/ - 情感/治愈类
# upbeat/ - 欢快/积极类
# cinematic/ - 电影/史诗类
# suspense/ - 悬疑/紧张类
# ambient/ - 氛围/环境类
