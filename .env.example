# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=optional_default_chat_id

# GLM-TTS (text-to-speech, direct API call)
# Endpoint: https://open.bigmodel.cn/api/paas/v4/audio/speech
# Auth: Authorization: Bearer <API_KEY>
GLM_TTS_API_KEY=your_glm_tts_api_key

# Kling 3.0 (video generation)
# Endpoint: https://api-singapore.klingai.com
# Auth: JWT HS256 (Access Key as iss, Secret Key as HMAC secret)
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key
KLING_API_URL=https://api-singapore.klingai.com
KLING_MAX_CONCURRENT=2
KLING_MAX_RETRIES=3
KLING_SHOT_TIMEOUT_MS=300000

# Episode defaults
EPISODE_MAX_SHOTS=8
EPISODE_MAX_DURATION=60
EPISODE_DEFAULT_STYLE=comic
EPISODES_DIR=./episodes
