# Video generation backend: "comfyui" (default) or "kling"
VIDEO_BACKEND=comfyui

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=optional_default_chat_id

# GLM-TTS (text-to-speech, direct API call)
GLM_TTS_API_KEY=your_glm_tts_api_key

# ComfyUI (Wan2.2 text-to-video, primary backend)
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
# COMFYUI_WORKFLOW_PATH=  # Optional: custom workflow JSON, default uses built-in Wan2.2 T2V
COMFYUI_MODEL=wan2.2_t2v_5B  # wan2.2_t2v_1.3B or wan2.2_t2v_5B

# Kling 3.0 (video generation, fallback backend)
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key
KLING_API_URL=https://api-beijing.klingai.com
KLING_MAX_CONCURRENT=2
KLING_MAX_RETRIES=3
KLING_SHOT_TIMEOUT_MS=300000

# Episode defaults
EPISODE_MAX_SHOTS=8
EPISODE_MAX_DURATION=60
EPISODE_DEFAULT_STYLE=comic
EPISODES_DIR=./episodes
