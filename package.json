{
  "name": "kais-aigc-movie",
  "version": "0.2.0",
  "description": "AI-generated movie production toolkit — types, services, and utilities for OpenClaw Skill",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./services/kling": {
      "types": "./dist/services/kling-api.d.ts",
      "import": "./dist/services/kling-api.js"
    },
    "./services/tts": {
      "types": "./dist/services/glm-tts.d.ts",
      "import": "./dist/services/glm-tts.js"
    },
    "./utils/ffmpeg": {
      "types": "./dist/utils/ffmpeg.d.ts",
      "import": "./dist/utils/ffmpeg.js"
    },
    "./utils/state": {
      "types": "./dist/utils/state-manager.d.ts",
      "import": "./dist/utils/state-manager.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "typescript": "^5.8.3"
  }
}
